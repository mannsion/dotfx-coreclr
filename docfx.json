{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "%DOCFX_NETCORE_APP_REF%",
          "files": [
            "ref/net10.0/*.dll"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "*.md",
          "toc.yml"
        ]
      },
      {
        "files": [
          "api/index.md",
          "api/toc.yml",
          "api/**/*.yml"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appName": ".NET 10 CLR API Documentation",
      "_appTitle": ".NET 10 CLR API Documentation",
      "_enableSearch": true,
      "_disableContribution": true,
      "_disableBreadcrumb": false,
      "_gitContribute": null
    },
    "template": [
      "default"
    ]
  }
}
